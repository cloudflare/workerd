-        "androidx.test.ext:junit:1.2.1",
-        "com.google.errorprone:error_prone_annotations:2.36.0",
-    ],
-    repositories = [
-        "https://maven.google.com",
-        "https://repo1.maven.org/maven2",
-    ],
-)
-use_repo(maven, "perfetto_maven")
