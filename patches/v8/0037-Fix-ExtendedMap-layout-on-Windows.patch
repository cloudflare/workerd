From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mikhail Aizatsky <maizatskyi@cloudflare.com>
Date: Tue, 16 Jun 2026 22:00:00 +0000
Subject: Fix ExtendedMap layout on Windows

MSVC's C++ object layout can place derived-class members into base-class
tail padding. ExtendedMap intentionally leaves kTaggedSize - 1 bytes after
bit_field_ex_ for subclasses, but Torque expects ExtendedMap itself to be
rounded up before JSInterceptorMap fields start.

Make the padding explicit in ExtendedMap's Torque and C++ layouts, and let
JSInterceptorMap start directly with its tagged fields. This keeps the C++
layout and generated Torque offsets consistent on Windows.

diff --git a/src/objects/js-interceptor-map.h b/src/objects/js-interceptor-map.h
index 546a15e1bc6ba44e528ba66e5a45a0f002a81cce..976b022ad9d3e2e1fcc3bcdc4c6b8bfc47c10d12 100644
--- a/src/objects/js-interceptor-map.h
+++ b/src/objects/js-interceptor-map.h
@@ -31,7 +31,6 @@ V8_OBJECT class JSInterceptorMap : public ExtendedMap {
   inline void clear_extended_padding();
 
  public:
-  uint8_t extended_padding_[kTaggedSize - 1];
   TaggedMember<InterceptorInfo> named_interceptor_;
   TaggedMember<InterceptorInfo> indexed_interceptor_;
 } V8_OBJECT_END;
diff --git a/src/objects/js-interceptor-map.tq b/src/objects/js-interceptor-map.tq
index 7a0838bb84d985467fd495e5b5fd10764bf82bf0..25f1d670094ec2f43739c992314fc474ebfd6d3c 100644
--- a/src/objects/js-interceptor-map.tq
+++ b/src/objects/js-interceptor-map.tq
@@ -8,8 +8,6 @@
 @hasSameInstanceTypeAsParent
 @doNotGenerateCast
 extern class JSInterceptorMap extends ExtendedMap {
-  @ifnot(TAGGED_SIZE_8_BYTES) extended_padding[3]: uint8;
-  @if(TAGGED_SIZE_8_BYTES) extended_padding[7]: uint8;
   named_interceptor: InterceptorInfo;
   indexed_interceptor: InterceptorInfo;
 }
diff --git a/src/objects/map.h b/src/objects/map.h
index 6b2c8e6acf7c1aa4f428af0ffce7cbb0da95c71d..0750c476a422034da005a2f65fd31f2c8aadfb38 100644
--- a/src/objects/map.h
+++ b/src/objects/map.h
@@ -1285,7 +1285,8 @@ V8_ABSTRACT_OBJECT class ExtendedMap : public Map {
   static const int kStartOfStrongExtendedFieldsOffset;
 
   std::atomic<uint8_t> bit_field_ex_;
-  // Leaves kTaggedSize-1 unused bytes, they will be used by subclasses.
+  // Pads ExtendedMap to kTaggedSize so subclasses start at tagged alignment.
+  uint8_t extended_padding_[kTaggedSize - 1];
 } V8_OBJECT_END;
 
 constexpr int ExtendedMapSizeForKind(ExtendedMapKind kind);
diff --git a/src/objects/map.tq b/src/objects/map.tq
index a32cb5bdc32ecfe48a0b885b900acefcf763767c..e34b51ae8b01e6683fd7d599001b1baf81f8c95b 100644
--- a/src/objects/map.tq
+++ b/src/objects/map.tq
@@ -113,7 +113,9 @@ bitfield struct ExtendedMapBitFields extends uint8 {
 @doNotGenerateCast
 extern class ExtendedMap extends Map {
   bit_field_ex: ExtendedMapBitFields;
-  // Leaves kTaggedSize-1 unused bytes, they will be used by subclasses.
+  // Pads ExtendedMap to kTaggedSize so subclasses start at tagged alignment.
+  @ifnot(TAGGED_SIZE_8_BYTES) extended_padding[3]: uint8;
+  @if(TAGGED_SIZE_8_BYTES) extended_padding[7]: uint8;
 }
 
 @export
