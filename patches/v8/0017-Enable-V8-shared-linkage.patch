diff --git a/BUILD.bazel b/BUILD.bazel
index 23f52ed12cecfcd7383cc3d389935ca487b8533e..8049d631cc50f2ca1059f81b59f5955337189d47 100644
--- a/BUILD.bazel
+++ b/BUILD.bazel
@@ -1505,6 +1505,7 @@ filegroup(
         "src/builtins/constants-table-builder.cc",
         "src/builtins/constants-table-builder.h",
         "src/builtins/data-view-ops.h",
+        "src/builtins/profile-data-reader.cc",
         "src/builtins/profile-data-reader.h",
         "src/builtins/superspread.h",
         "src/codegen/aligned-slot-allocator.cc",
