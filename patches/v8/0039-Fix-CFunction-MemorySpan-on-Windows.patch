From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Mikhail Aizatsky <maizatskyi@cloudflare.com>
Date: Wed, 17 Jun 2026 16:00:00 +0000
Subject: Fix CFunction MemorySpan declarations on Windows

MSVC's std::span instantiates iterator types that perform pointer arithmetic
when a span alias is used in a function declaration. v8-template.h declares
MemorySpan<const CFunction> parameters while only forward-declaring CFunction,
which leaves the type incomplete and fails under clang-cl with MSVC's STL.

Include v8-fast-api-calls.h before these declarations so CFunction is complete.

diff --git a/include/v8-template.h b/include/v8-template.h
index 49f68abc64cbe746863969edcc0d190edac35c79..f250e6ce199d76070ae0e9fe323b09ebebf07498 100644
--- a/include/v8-template.h
+++ b/include/v8-template.h
@@ -9,15 +9,15 @@
 #include <string_view>
 
 #include "v8-data.h"               // NOLINT(build/include_directory)
 #include "v8-exception.h"          // NOLINT(build/include_directory)
+#include "v8-fast-api-calls.h"     // NOLINT(build/include_directory)
 #include "v8-function-callback.h"  // NOLINT(build/include_directory)
 #include "v8-local-handle.h"       // NOLINT(build/include_directory)
 #include "v8-memory-span.h"        // NOLINT(build/include_directory)
 #include "v8-object.h"             // NOLINT(build/include_directory)
 #include "v8config.h"              // NOLINT(build/include_directory)
 
 namespace v8 {
 
-class CFunction;
 class FunctionTemplate;
 class ObjectTemplate;
 class Signature;
