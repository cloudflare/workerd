directories = glob(
    ["*"],
    exclude = glob(
        ["*"],
        exclude_directories = 1,
    ) + [
        ".*",
    ],
    exclude_directories = 0,
)

[filegroup(
    name = dir,
    srcs = glob(["{}/**/*".format(dir)]),
    visibility = ["//visibility:public"],
) for dir in directories]
