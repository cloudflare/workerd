"""Bazel macro for building per-isolate bootstrap script bundles.

Compiles TypeScript scripts to JavaScript, generates V8 compile caches,
and packages everything into a Cap'n Proto Bundle embedded in a C++ library.

Unlike wd_ts_bundle (for ESM modules), this macro produces a bundle of
CommonJS-style scripts with bare specifier names, intended for synchronous
execution at isolate creation time.
"""

load("@aspect_rules_ts//ts:defs.bzl", "ts_config", "ts_project")
load("@bazel_skylib//rules:copy_file.bzl", "copy_file")
load("@capnp-cpp//src/capnp:cc_capnp_library.bzl", "cc_capnp_library")
load("@workerd//:build/wd_js_bundle.bzl", _gen_compile_cache = "compile_cache_rule")

SCRIPT_CAPNP_TEMPLATE = """@{schema_id};

# generated by @workerd//build/wd_ts_script_bundle.bzl

using Modules = import "/workerd/jsg/modules.capnp";

const {const_name} :Modules.Bundle = (
  modules = [
{modules}
]);
"""

SCRIPT_MODULE_TEMPLATE = """    (name = "{name}", src = embed "{path}", type = internal, {extras})"""

def _to_js(file_name):
    """Convert a .ts filename to .js."""
    if file_name.endswith(".ts"):
        return file_name.removesuffix(".ts") + ".js"
    return file_name

def _script_name(js_file):
    """Convert a .js filename to a bare require() specifier.

    Examples:
      main.js            -> main
      foo.js             -> foo
      utils/helpers.js   -> utils/helpers
    """
    return js_file.removesuffix(".js")

def _flat_name(name):
    """Flatten a path for use as a file target (replace / with _)."""
    return name.replace("/", "_")

def _to_bundle_const_name(name):
    """Convert a target name to a capnp constant name.

    Example: per_isolate -> perIsolateBundle
    capnpc-c++ converts lowerCamelCase to SCREAMING_SNAKE_CASE,
    so perIsolateBundle becomes PER_ISOLATE_BUNDLE in C++.
    """
    parts = name.split("_")
    camel = parts[0] + "".join([p.capitalize() for p in parts[1:]])
    return camel + "Bundle"

def _relative_path(file_path, dir_path):
    if not file_path.startswith(dir_path):
        fail("file_path must start with dir_path: " + file_path + " vs " + dir_path)
    return file_path.removeprefix(dir_path)

def _get_compile_cache(compile_cache, m):
    if not compile_cache:
        return None
    files = m.files.to_list()
    if len(files) != 1:
        fail("only single file expected")
    return compile_cache.get(files[0].path)

def _gen_script_bundle_capnp_impl(ctx):
    """Generate a .capnp file for a script bundle with bare specifier names."""
    output_dir = ctx.outputs.out.dirname + "/"

    compile_cache = {}
    if ctx.attr.compile_cache:
        locations = ctx.expand_location(
            "$(locations {})".format(ctx.attr.compile_cache.label),
            ctx.attr.data,
        ).split(" ")
        for loc in locations:
            compile_cache[loc.removesuffix("_cache")] = loc

    modules = []
    for m in ctx.attr.scripts:
        script_name = ctx.attr.scripts[m]
        path = _relative_path(
            ctx.expand_location("$(location {})".format(m.label), ctx.attr.data),
            output_dir,
        )

        cache_extra = ""
        cache_file = _get_compile_cache(compile_cache, m)
        if cache_file:
            cache_extra = "compileCache = embed \"{}\", ".format(
                _relative_path(cache_file, output_dir),
            )

        modules.append(SCRIPT_MODULE_TEMPLATE.format(
            name = script_name,
            path = path,
            extras = cache_extra,
        ))

    content = SCRIPT_CAPNP_TEMPLATE.format(
        schema_id = ctx.attr.schema_id,
        modules = ",\n".join(modules),
        const_name = ctx.attr.const_name,
    )
    ctx.actions.write(ctx.outputs.out, content)

_gen_script_bundle_capnp = rule(
    implementation = _gen_script_bundle_capnp_impl,
    attrs = {
        "schema_id": attr.string(mandatory = True),
        "out": attr.output(mandatory = True),
        "const_name": attr.string(mandatory = True),
        "scripts": attr.label_keyed_string_dict(allow_files = True),
        "data": attr.label_list(allow_files = True),
        "compile_cache": attr.label(),
    },
)

def wd_ts_script_bundle(
        name,
        schema_id,
        scripts,
        tsconfig_json,
        deps = [],
        gen_compile_cache = True):
    """Build a per-isolate script bundle from TypeScript sources.

    Compiles TypeScript to JavaScript, optionally generates V8 compile caches,
    and produces a cc_capnp_library target containing all scripts as an
    embedded Cap'n Proto Bundle constant.

    Scripts are named with bare specifiers (e.g., "main", "foo") rather
    than prefixed module names. All scripts use type = internal.

    Args:
      name: Target name. Produces a cc_capnp_library with this name.
      schema_id: Capnp schema id (generate with `capnp id`).
      scripts: List of .ts source files (typically from glob).
      tsconfig_json: Path to tsconfig.json.
      deps: Additional TypeScript dependencies.
      gen_compile_cache: Generate V8 compile caches (default True).
    """

    # 1. TypeScript compilation (type-stripping only)
    ts_config(
        name = name + "@tsconfig",
        src = tsconfig_json,
        deps = ["@workerd//tools:base-tsconfig"],
    )

    ts_srcs = [s for s in scripts if s.endswith(".ts")]
    non_dts = [s for s in ts_srcs if not s.endswith(".d.ts")]

    ts_project(
        name = name + "@tsproject",
        srcs = ts_srcs,
        allow_js = True,
        declaration = True,
        composite = True,
        tsconfig = ":" + name + "@tsconfig",
        deps = deps,
        visibility = ["//visibility:public"],
    )

    # 2. Build script name mapping and copy files for capnp embed.
    #    capnp compiler cannot embed files outside the rule's directory subtree,
    #    so we copy JS outputs into the current package with flattened names.
    #    e.g., main.js -> main, utils/helpers.js -> utils_helpers
    js_files = [_to_js(s) for s in non_dts]

    scripts_dict = {}
    for js in js_files:
        sname = _script_name(js)
        flat = _flat_name(sname)
        copy_file(name = flat + "@copy", src = js, out = flat)
        scripts_dict[flat] = sname

    # 3. Optional: generate V8 compile caches
    data = list(scripts_dict.keys())
    compile_cache = None
    compile_cache_deps = []

    if gen_compile_cache:
        _gen_compile_cache(
            name = name + "@compile_cache",
            srcs = list(scripts_dict.keys()),
        )
        compile_cache = name + "@compile_cache"
        compile_cache_deps = [compile_cache]
        data = data + [compile_cache]

    # 4. Generate .capnp file with bare script names
    _gen_script_bundle_capnp(
        name = name + "@gen",
        out = name + ".capnp",
        schema_id = schema_id,
        const_name = _to_bundle_const_name(name),
        scripts = scripts_dict,
        data = data,
        compile_cache = compile_cache,
    )

    # 5. Compile capnp to C++
    cc_capnp_library(
        name = name,
        srcs = [name + ".capnp"],
        strip_include_prefix = "",
        visibility = ["//visibility:public"],
        data = data,
        deps = ["@workerd//src/workerd/jsg:modules_capnp"],
        include_prefix = name,
    )
