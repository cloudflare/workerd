using Workerd = import "/workerd/workerd.capnp";

# Tests that secp256k1 ECDSA is rejected when the SECP256K1_ECDSA autogate is
# off. Only runs in the default variant; @all-autogates is skipped.

const unitTests :Workerd.Config = (
  services = [
    ( name = "crypto-secp256k1-disabled",
      worker = (
        modules = [
          (name = "worker", esModule = embed "crypto-secp256k1-disabled-test.js")
        ],
        compatibilityFlags = ["nodejs_compat"],
      )
    ),
  ],
);
